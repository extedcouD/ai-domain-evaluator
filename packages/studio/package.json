{
  "name": "@evaluator/studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser tool to author the KB manifest and view/compare coverage. A node:http + MongoDB API (per-author workspaces, review/merge) plus a Vite + React UI.",
  "exports": {
    ".": "./src/server.ts",
    "./manifest-folder": "./src/manifest-folder.ts"
  },
  "scripts": {
    "dev": "tsx src/dev.ts",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@evaluator/core": "workspace:*",
    "@evaluator/provider-anthropic": "workspace:*",
    "@evaluator/provider-openai": "workspace:*",
    "async-mutex": "^0.5.0",
    "mongodb": "^6.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^25.0.1",
    "mongodb-memory-server": "^10.1.4",
    "vite": "^7.1.5"
  }
}
