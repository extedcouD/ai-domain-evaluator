    "@evaluator/provider-anthropic": "workspace:*",
    "@evaluator/provider-openai": "workspace:*",
    "@evaluator/reporter": "workspace:*",
    "@evaluator/studio": "workspace:*",
    "dotenv": "^17.4.2",
    "yaml": "^2.9.0"
  }
}
