{
  "name": "@evaluator/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The scripted front-end: --health, --check-schema, --coverage, --validate, and one-shot prose. Reads the environment, selects a provider, and drives the core probes.",
