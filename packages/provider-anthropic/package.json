{
  "name": "@evaluator/provider-anthropic",
  "version": "0.0.0",
  "type": "module",
  "description": "Anthropic Messages API transport adapter for @evaluator/core. Implements the Llm seam, including schema enforcement via a forced single-tool call. The only package permitted to import the Anthropic SDK.",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@evaluator/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.111.0"
  }
}
