# Copy to `.env` and fill in. `docker compose --env-file .env up -d --build`.

# ---- your domain (must resolve to this EC2's public IP) ----
KB_HOST=kb.yourcompany.com

# ---- the KB git repo (its ROOT is the KB: manifest.meta.yaml, topics/, access.yaml) ----
KB_GITHUB_REPO=yourorg/your-kb-repo
# A GitHub token with `repo` scope. The SERVER uses it to fetch/push each user's branch and to
# open + merge pull requests. Prefer a fine-grained token or a bot account.
KB_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Emails allowed to merge proposals when the repo has no access.yaml yet (access.yaml takes over once added).
KB_ADMINS=alice@yourcompany.com,bob@yourcompany.com

# ---- SSO: a GitHub OAuth App (Settings -> Developer settings -> OAuth Apps) ----
# Authorization callback URL must be: https://<KB_HOST>/oauth2/callback
OAUTH_CLIENT_ID=Iv1_xxxxxxxx
OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# 32-byte secret: openssl rand -base64 32
OAUTH_COOKIE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Restrict logins to your GitHub org (members only).
GITHUB_ORG=yourorg
