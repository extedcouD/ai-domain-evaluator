# Copy to `.env` and fill in. `docker compose --env-file .env up -d --build`.

# ---- your domain (must resolve to this EC2's public IP) ----
KB_HOST=kb.yourcompany.com

# ---- the KB store (MongoDB) ----
# MongoDB is part of this Compose stack. The named `mongo-data` volume retains its data.
MONGODB_URI=mongodb://mongo:27017
KB_DB_NAME=kb_studio
# Admin emails seeded on FIRST boot (when no access policy exists yet). After that the Admin page governs
# access; anyone who signs in is a read-only viewer until an admin grants them write scopes.
KB_ADMINS=extedcoud@gmail.com

# ---- SSO: a GitHub OAuth App (Settings -> Developer settings -> OAuth Apps) ----
# Authorization callback URL must be: https://<KB_HOST>/oauth2/callback
OAUTH_CLIENT_ID=Iv1_xxxxxxxx
OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# 32-byte secret: openssl rand -base64 32
OAUTH_COOKIE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
